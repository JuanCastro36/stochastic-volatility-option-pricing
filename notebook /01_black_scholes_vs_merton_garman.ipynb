from pathlib import Path

import numpy as np
import pandas as pd
import matplotlib.pyplot as plt


# ============================================================
# Project folders
# ============================================================

DATA_RAW_DIR = Path("data/raw")
DATA_PROCESSED_DIR = Path("data/processed")
FIGURES_DIR = Path("reports/figures")
TABLES_DIR = Path("reports/tables")

for folder in [DATA_RAW_DIR, DATA_PROCESSED_DIR, FIGURES_DIR, TABLES_DIR]:
    folder.mkdir(parents=True, exist_ok=True)


# ============================================================
# Global parameters
# ============================================================

SYMBOLS = ["AMZN", "TSLA", "GOOGL", "AAPL", "MSFT"]

RISK_FREE_RATE = 0.05

# Lighter defaults for GitHub reproducibility.
# Increase these values for more accurate but slower simulations.
N_PATHS_BS = 50_000
N_PATHS_MG = 20_000
N_STEPS_MG = 1_000

SEED_BS = 10
SEED_MG = 20

MAX_TAU_DAYS = 60

def load_master_dataset(input_file):
    """
    Load the raw master dataset.

    Parameters
    ----------
    input_file : str or Path
        Path to the master CSV file.

    Returns
    -------
    pd.DataFrame
        Raw master dataset.
    """

    input_file = Path(input_file)

    if not input_file.exists():
        raise FileNotFoundError(f"File not found: {input_file}")

    df = pd.read_csv(input_file)

    return df


def standardize_column_names(df):
    """
    Standardize column names to lowercase snake-like format.
    """

    clean_df = df.copy()
    clean_df.columns = (
        clean_df.columns
        .str.strip()
        .str.lower()
        .str.replace(" ", "_")
    )

    return clean_df


def filter_options_by_symbol(master_df, symbol, output_dir=DATA_PROCESSED_DIR):
    """
    Filter option records for a selected underlying symbol.

    The function expects a column called 'act_symbol'.
    """

    df = standardize_column_names(master_df)

    if "act_symbol" not in df.columns:
        raise ValueError("Column 'act_symbol' was not found in the master dataset.")

    filtered = df[df["act_symbol"] == symbol].copy()

    if filtered.empty:
        raise ValueError(f"No option records found for symbol {symbol}.")

    output_file = Path(output_dir) / f"option_{symbol}.csv"
    filtered.to_csv(output_file, index=False)

    print(f"Saved option data for {symbol}: {output_file}")

    return filtered


def extract_volatility_by_symbol(master_df, symbol, output_dir=DATA_PROCESSED_DIR):
    """
    Extract a daily implied volatility series from the master dataset.

    This works only if the master dataset contains 'iv_current'.
    The function aggregates possible duplicates by date using the mean.
    """

    df = standardize_column_names(master_df)

    required_columns = {"act_symbol", "date", "iv_current"}

    if not required_columns.issubset(df.columns):
        print(
            f"Could not extract volatility for {symbol}: "
            f"required columns {required_columns} were not found."
        )
        return None

    filtered = df[df["act_symbol"] == symbol].copy()

    if filtered.empty:
        raise ValueError(f"No volatility records found for symbol {symbol}.")

    filtered["date"] = pd.to_datetime(filtered["date"], errors="coerce")
    filtered["iv_current"] = pd.to_numeric(filtered["iv_current"], errors="coerce")

    volatility = (
        filtered
        .dropna(subset=["date", "iv_current"])
        .groupby("date", as_index=False)["iv_current"]
        .mean()
        .sort_values("date")
    )

    output_file = Path(output_dir) / f"volatility_{symbol}.csv"
    volatility.to_csv(output_file, index=False)

    print(f"Saved volatility data for {symbol}: {output_file}")

    return volatility


def create_symbol_files_from_master(input_file, symbols=SYMBOLS):
    """
    Create option_SYMBOL.csv and volatility_SYMBOL.csv files from a master file.
    """

    master_df = load_master_dataset(input_file)

    option_files = {}
    volatility_files = {}

    for symbol in symbols:
        try:
            option_files[symbol] = filter_options_by_symbol(master_df, symbol)
        except Exception as error:
            print(f"Option filtering failed for {symbol}: {error}")

        try:
            volatility_files[symbol] = extract_volatility_by_symbol(master_df, symbol)
        except Exception as error:
            print(f"Volatility extraction failed for {symbol}: {error}")

    return option_files, volatility_files


