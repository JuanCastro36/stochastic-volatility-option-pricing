def normalize_option_dataframe(df):
    """
    Clean and normalize the option dataframe.
    """

    clean_df = standardize_column_names(df)

    required_columns = {
        "date",
        "expiration",
        "strike",
        "call_put",
        "bid",
        "ask"
    }

    missing_columns = required_columns.difference(clean_df.columns)

    if missing_columns:
        raise ValueError(f"Missing option columns: {missing_columns}")

    clean_df["date"] = pd.to_datetime(clean_df["date"], errors="coerce")
    clean_df["expiration"] = pd.to_datetime(clean_df["expiration"], errors="coerce")
    clean_df["strike"] = pd.to_numeric(clean_df["strike"], errors="coerce")
    clean_df["bid"] = pd.to_numeric(clean_df["bid"], errors="coerce")
    clean_df["ask"] = pd.to_numeric(clean_df["ask"], errors="coerce")

    clean_df["call_put"] = (
        clean_df["call_put"]
        .astype(str)
        .str.strip()
        .str.lower()
        .replace({
            "c": "call",
            "call": "call",
            "calls": "call",
            "p": "put",
            "put": "put",
            "puts": "put"
        })
    )

    clean_df = clean_df.dropna(
        subset=["date", "expiration", "strike", "bid", "ask", "call_put"]
    )

    clean_df = clean_df[clean_df["call_put"].isin(["call", "put"])]
    clean_df = clean_df[clean_df["strike"] > 0]
    clean_df = clean_df[clean_df["bid"] >= 0]
    clean_df = clean_df[clean_df["ask"] >= 0]
    clean_df = clean_df[clean_df["ask"] >= clean_df["bid"]]

    clean_df = clean_df.sort_values(["date", "expiration", "strike", "call_put"])

    return clean_df


def normalize_volatility_dataframe(df):
    """
    Clean and normalize the implied volatility dataframe.
    """

    clean_df = standardize_column_names(df)

    required_columns = {"date", "iv_current"}
    missing_columns = required_columns.difference(clean_df.columns)

    if missing_columns:
        raise ValueError(f"Missing volatility columns: {missing_columns}")

    clean_df["date"] = pd.to_datetime(clean_df["date"], errors="coerce")
    clean_df["iv_current"] = pd.to_numeric(clean_df["iv_current"], errors="coerce")

    clean_df = clean_df.dropna(subset=["date", "iv_current"])
    clean_df = clean_df[clean_df["iv_current"] > 0]

    # Convert percentage values to decimal values when needed.
    clean_df.loc[clean_df["iv_current"] > 1.0, "iv_current"] /= 100.0

    clean_df = clean_df.sort_values("date")

    return clean_df


def load_symbol_data(symbols=SYMBOLS, data_dir=DATA_PROCESSED_DIR):
    """
    Load option and volatility files for all selected symbols.

    Expected files:
        option_SYMBOL.csv
        volatility_SYMBOL.csv
    """

    options = {}
    volatilities = {}

    for symbol in symbols:
        option_file = Path(data_dir) / f"option_{symbol}.csv"
        volatility_file = Path(data_dir) / f"volatility_{symbol}.csv"

        if not option_file.exists():
            raise FileNotFoundError(f"Option file not found: {option_file}")

        if not volatility_file.exists():
            raise FileNotFoundError(f"Volatility file not found: {volatility_file}")

        raw_options = pd.read_csv(option_file)
        raw_volatility = pd.read_csv(volatility_file)

        options[symbol] = normalize_option_dataframe(raw_options)
        volatilities[symbol] = normalize_volatility_dataframe(raw_volatility)

        print(
            f"{symbol}: loaded {len(options[symbol])} option rows "
            f"and {len(volatilities[symbol])} volatility rows."
        )

    return options, volatilities

options, volatilities = load_symbol_data(SYMBOLS)

def build_call_put_table(option_day):
    """
    Build a call-put table indexed by date, expiration and strike.

    The output contains bid and ask prices for calls and puts.
    """

    table = option_day.pivot_table(
        index=["date", "expiration", "strike"],
        columns="call_put",
        values=["bid", "ask"],
        aggfunc="mean"
    )

    table = table.dropna()

    return table


def compute_mid_prices(row):
    """
    Compute call and put mid-prices from a pivot-table row.
    """

    call_mid = 0.5 * (row[("bid", "call")] + row[("ask", "call")])
    put_mid = 0.5 * (row[("bid", "put")] + row[("ask", "put")])

    return call_mid, put_mid


def reconstruct_spot_from_put_call_parity(call_mid, put_mid, strike, tau, r):
    """
    Reconstruct the underlying price from put-call parity.

    S0 = C - P + K exp(-r tau)
    """

    spot = call_mid - put_mid + strike * np.exp(-r * tau)

    return float(spot)


def select_contract_by_parity(
    option_data,
    volatility_data,
    r=RISK_FREE_RATE,
    selected_date=None,
    max_tau_days=MAX_TAU_DAYS
):
    """
    Select one option contract for a given date.

    The function:
    1. selects a date,
    2. selects the nearest valid expiration,
    3. keeps strikes with both call and put prices,
    4. reconstructs the underlying price through put-call parity,
    5. chooses the strike closest to the reconstructed spot.
    """

    if selected_date is None:
        selected_date = option_data["date"].min()
    else:
        selected_date = pd.to_datetime(selected_date)

    option_day = option_data[option_data["date"] == selected_date].copy()

    if option_day.empty:
        raise ValueError(f"No option data found for date {selected_date}.")

    option_day["tau_days"] = (
        option_day["expiration"] - option_day["date"]
    ).dt.days

    option_day = option_day[option_day["tau_days"] > 0]

    if max_tau_days is not None:
        option_day = option_day[option_day["tau_days"] <= max_tau_days]

    if option_day.empty:
        raise ValueError(f"No valid expiration found for date {selected_date}.")

    nearest_tau = option_day["tau_days"].min()
    option_day = option_day[option_day["tau_days"] == nearest_tau].copy()

    table = build_call_put_table(option_day)

    if table.empty:
        raise ValueError("No strike with both call and put prices was found.")

    candidates = []

    for index_value, row in table.iterrows():
        date_value, expiration, strike = index_value

        call_mid, put_mid = compute_mid_prices(row)

        tau = (expiration - date_value).days / 365.0
        spot = reconstruct_spot_from_put_call_parity(
            call_mid=call_mid,
            put_mid=put_mid,
            strike=strike,
            tau=tau,
            r=r
        )

        if np.isfinite(spot) and spot > 0:
            candidates.append({
                "date": date_value,
                "expiration": expiration,
                "strike": float(strike),
                "tau": float(tau),
                "call_mid": float(call_mid),
                "put_mid": float(put_mid),
                "S0": float(spot),
                "atm_distance": abs(float(spot) - float(strike))
            })

    if not candidates:
        raise ValueError("No valid put-call parity candidate was found.")

    candidates_df = pd.DataFrame(candidates)
    selected = candidates_df.sort_values("atm_distance").iloc[0]

    volatility_day = volatility_data[volatility_data["date"] == selected["date"]]

    if volatility_day.empty:
        raise ValueError(f"No implied volatility found for date {selected['date']}.")

    sigma = float(volatility_day["iv_current"].iloc[0])

    if sigma > 1.0:
        sigma /= 100.0

    selected = selected.to_dict()
    selected["sigma"] = sigma
    selected["v0"] = sigma**2

    return selected


def build_reconstructed_sv_series(
    option_data,
    volatility_data,
    r=RISK_FREE_RATE,
    max_tau_days=MAX_TAU_DAYS
):
    """
    Build a time series of reconstructed spot and implied variance.

    Columns:
        date, expiration, strike, tau, S, sigma, V
    """

    records = []

    for date_value in sorted(option_data["date"].unique()):
        try:
            selected = select_contract_by_parity(
                option_data=option_data,
                volatility_data=volatility_data,
                r=r,
                selected_date=date_value,
                max_tau_days=max_tau_days
            )

            records.append({
                "date": selected["date"],
                "expiration": selected["expiration"],
                "strike": selected["strike"],
                "tau": selected["tau"],
                "S": selected["S0"],
                "sigma": selected["sigma"],
                "V": selected["sigma"] ** 2
            })

        except Exception:
            continue

    if not records:
        raise ValueError("No valid reconstructed observations were found.")

    series = pd.DataFrame(records)
    series = series.replace([np.inf, -np.inf], np.nan)
    series = series.dropna(subset=["date", "S", "V", "sigma"])
    series = series[series["S"] > 0]
    series = series[series["V"] > 0]
    series = series.sort_values("date").reset_index(drop=True)

    if len(series) < 3:
        raise ValueError("The reconstructed series is too short.")

    return series

def raw_moments_black_scholes(S0, tau, r, sigma, max_order=4):
    """
    Compute raw moments E[S_T^q] under Black-Scholes.

    Under Black-Scholes, log(S_T) is normally distributed.
    """

    log_mean = np.log(S0) + (r - 0.5 * sigma**2) * tau
    log_variance = sigma**2 * tau

    raw_moments = {}

    for q in range(1, max_order + 1):
        raw_moments[q] = np.exp(q * log_mean + 0.5 * q**2 * log_variance)

    return raw_moments


def central_moments_from_raw(raw_moments):
    """
    Convert raw moments m1, m2, m3, m4 into mean, variance,
    skewness and kurtosis.
    """

    m1 = raw_moments[1]
    m2 = raw_moments[2]
    m3 = raw_moments[3]
    m4 = raw_moments[4]

    variance = m2 - m1**2
    third_central = m3 - 3 * m2 * m1 + 2 * m1**3
    fourth_central = m4 - 4 * m3 * m1 + 6 * m2 * m1**2 - 3 * m1**4

    standard_deviation = np.sqrt(max(variance, 0.0))

    skewness = (
        third_central / standard_deviation**3
        if standard_deviation > 0
        else np.nan
    )

    kurtosis = (
        fourth_central / standard_deviation**4
        if standard_deviation > 0
        else np.nan
    )

    return {
        "mean": m1,
        "variance": variance,
        "skewness": skewness,
        "kurtosis": kurtosis
    }


def black_scholes_closed_moments(S0, tau, r, sigma):
    """
    Compute closed-form Black-Scholes moments.
    """

    raw_moments = raw_moments_black_scholes(
        S0=S0,
        tau=tau,
        r=r,
        sigma=sigma,
        max_order=4
    )

    moments = central_moments_from_raw(raw_moments)
    moments["raw_moments"] = raw_moments

    return moments


def simulate_black_scholes_terminal_price(
    S0,
    tau,
    r,
    sigma,
    n_paths=N_PATHS_BS,
    seed=SEED_BS
):
    """
    Simulate terminal prices under Black-Scholes exactly.
    """

    rng = np.random.default_rng(seed)
    standard_normals = rng.normal(0.0, 1.0, size=n_paths)

    terminal_prices = S0 * np.exp(
        (r - 0.5 * sigma**2) * tau
        + sigma * np.sqrt(tau) * standard_normals
    )

    return terminal_prices

def simulate_merton_garman_terminal_price(
    S0,
    tau,
    r,
    v0,
    mu_tilde,
    xi,
    rho,
    n_paths=N_PATHS_MG,
    n_steps=N_STEPS_MG,
    seed=SEED_MG
):
    """
    Simulate terminal prices under a lognormal Merton-Garman-type
    stochastic variance model.

    Variance dynamics:
        dV_t = mu_tilde V_t dt + xi V_t dW_t^Q

    Price dynamics:
        dS_t = r S_t dt + sqrt(V_t) S_t dW_t^R

    Correlation:
        dW_t^R dW_t^Q = rho dt
    """

    if not (-1.0 <= rho <= 1.0):
        raise ValueError("rho must be between -1 and 1.")

    if S0 <= 0 or v0 <= 0 or tau <= 0:
        raise ValueError("S0, v0 and tau must be positive.")

    rng = np.random.default_rng(seed)

    dt = tau / n_steps
    sqrt_dt = np.sqrt(dt)

    log_price = np.full(n_paths, np.log(S0), dtype=float)
    log_variance = np.full(n_paths, np.log(v0), dtype=float)
    variance = np.exp(log_variance)

    integrated_variance = np.zeros(n_paths, dtype=float)
    variance_brownian_integral = np.zeros(n_paths, dtype=float)

    independent_weight = np.sqrt(max(1.0 - rho**2, 0.0))

    for _ in range(n_steps):
        variance_old = variance
        sqrt_variance_old = np.sqrt(variance_old)

        z_variance = rng.normal(0.0, 1.0, size=n_paths)
        z_independent = rng.normal(0.0, 1.0, size=n_paths)

        dW_variance = sqrt_dt * z_variance
        dW_independent = sqrt_dt * z_independent

        log_variance = (
            log_variance
            + (mu_tilde - 0.5 * xi**2) * dt
            + xi * dW_variance
        )

        variance = np.exp(log_variance)

        integrated_variance += variance_old * dt
        variance_brownian_integral += sqrt_variance_old * dW_variance

        dW_price = rho * dW_variance + independent_weight * dW_independent

        log_price = (
            log_price
            + (r - 0.5 * variance_old) * dt
            + sqrt_variance_old * dW_price
        )

    terminal_prices = np.exp(log_price)

    return terminal_prices, integrated_variance, variance_brownian_integral


def conditional_raw_moments_merton_garman(
    S0,
    tau,
    r,
    rho,
    integrated_variance,
    variance_brownian_integral,
    orders=(1, 2, 3, 4)
):
    """
    Estimate raw moments of S_T under Merton-Garman using conditional
    expectation given integrated variance and the variance Brownian integral.
    """

    integrated_variance = np.asarray(integrated_variance)
    variance_brownian_integral = np.asarray(variance_brownian_integral)

    log_S0 = np.log(S0)

    raw_moments = {}

    conditional_mean = (
        log_S0
        + r * tau
        - 0.5 * integrated_variance
        + rho * variance_brownian_integral
    )

    conditional_variance = (1.0 - rho**2) * integrated_variance

    for q in orders:
        conditional_estimator = np.exp(
            q * conditional_mean
            + 0.5 * q**2 * conditional_variance
        )

        raw_moments[q] = conditional_estimator.mean()

    return raw_moments

def sample_moments(values):
    """
    Compute sample mean, variance, skewness and kurtosis.
    """

    values = np.asarray(values, dtype=float)
    values = values[np.isfinite(values)]

    if len(values) == 0:
        raise ValueError("No finite values available.")

    mean = np.mean(values)
    centered = values - mean

    variance = np.mean(centered**2)
    third_central = np.mean(centered**3)
    fourth_central = np.mean(centered**4)

    standard_deviation = np.sqrt(variance)

    skewness = (
        third_central / standard_deviation**3
        if standard_deviation > 0
        else np.nan
    )

    kurtosis = (
        fourth_central / standard_deviation**4
        if standard_deviation > 0
        else np.nan
    )

    standard_error_mean = standard_deviation / np.sqrt(len(values))

    return {
        "mean": mean,
        "variance": variance,
        "skewness": skewness,
        "kurtosis": kurtosis,
        "se_mean": standard_error_mean
    }


def estimate_merton_garman_parameters(series, r=RISK_FREE_RATE):
    """
    Estimate Merton-Garman parameters from reconstructed S and V series.

    This is a historical approximation, not a full option-price calibration.
    """

    df = series.copy()
    df = df.sort_values("date").reset_index(drop=True)

    df = df.replace([np.inf, -np.inf], np.nan)
    df = df.dropna(subset=["date", "S", "V"])
    df = df[df["S"] > 0]
    df = df[df["V"] > 0]

    if len(df) < 3:
        raise ValueError("Series is too short for parameter estimation.")

    dates = pd.to_datetime(df["date"])
    log_price = np.log(df["S"].values)
    log_variance = np.log(df["V"].values)
    variance = df["V"].values

    dt = dates.diff().dt.days.iloc[1:].values / 365.0
    dX = np.diff(log_price)
    dY = np.diff(log_variance)
    V_start = variance[:-1]

    mask = (
        np.isfinite(dt)
        & np.isfinite(dX)
        & np.isfinite(dY)
        & np.isfinite(V_start)
        & (dt > 0)
        & (V_start > 0)
    )

    dt = dt[mask]
    dX = dX[mask]
    dY = dY[mask]
    V_start = V_start[mask]

    if len(dY) < 2:
        raise ValueError("Not enough clean increments for estimation.")

    variance_dY = np.var(dY, ddof=1)
    mean_dt = np.mean(dt)

    xi_hat = np.sqrt(max(variance_dY / mean_dt, 0.0))

    if xi_hat <= 0:
        raise ValueError("Estimated xi is not positive.")

    drift_log_variance = np.sum(dY) / np.sum(dt)
    mu_tilde_hat = drift_log_variance + 0.5 * xi_hat**2

    epsilon_variance = (
        dY - (mu_tilde_hat - 0.5 * xi_hat**2) * dt
    ) / (xi_hat * np.sqrt(dt))

    price_residual = (
        dX - (r - 0.5 * V_start) * dt
    ) / (np.sqrt(V_start) * np.sqrt(dt))

    rho_hat = np.corrcoef(price_residual, epsilon_variance)[0, 1]

    if not np.isfinite(rho_hat):
        rho_hat = 0.0

    rho_hat = float(np.clip(rho_hat, -0.99, 0.99))

    return {
        "mu_tilde": float(mu_tilde_hat),
        "xi": float(xi_hat),
        "rho": rho_hat
    }


def fallback_merton_garman_parameters(volatility_data):
    """
    Provide fallback parameters if historical estimation fails.
    """

    clean_iv = volatility_data["iv_current"].replace([np.inf, -np.inf], np.nan)
    clean_iv = clean_iv.dropna()
    clean_iv = clean_iv[clean_iv > 0]

    if len(clean_iv) == 0:
        sigma_bar = 0.30
    else:
        sigma_bar = float(clean_iv.mean())

    if sigma_bar > 1.0:
        sigma_bar /= 100.0

    return {
        "mu_tilde": 0.20,
        "xi": max(0.10, 0.5 * sigma_bar),
        "rho": -0.50
    }

def analyze_symbol(
    symbol,
    option_data,
    volatility_data,
    r=RISK_FREE_RATE,
    n_paths_bs=N_PATHS_BS,
    n_paths_mg=N_PATHS_MG,
    n_steps_mg=N_STEPS_MG,
    seed_bs=SEED_BS,
    seed_mg=SEED_MG
):
    """
    Run the full BS vs Merton-Garman comparison for one symbol.
    """

    # Reconstruct the historical S and V series.
    sv_series = build_reconstructed_sv_series(
        option_data=option_data,
        volatility_data=volatility_data,
        r=r,
        max_tau_days=MAX_TAU_DAYS
    )

    # Estimate stochastic volatility parameters.
    try:
        mg_params = estimate_merton_garman_parameters(sv_series, r=r)
        estimation_status = "estimated"
    except Exception as error:
        print(f"{symbol}: parameter estimation failed: {error}")
        mg_params = fallback_merton_garman_parameters(volatility_data)
        estimation_status = "fallback"

    # Select one representative contract for moment comparison.
    contract = select_contract_by_parity(
        option_data=option_data,
        volatility_data=volatility_data,
        r=r,
        selected_date=None,
        max_tau_days=MAX_TAU_DAYS
    )

    S0 = contract["S0"]
    tau = contract["tau"]
    sigma = contract["sigma"]
    v0 = sigma**2

    # Black-Scholes closed moments.
    bs_closed = black_scholes_closed_moments(
        S0=S0,
        tau=tau,
        r=r,
        sigma=sigma
    )

    # Black-Scholes Monte Carlo.
    terminal_bs = simulate_black_scholes_terminal_price(
        S0=S0,
        tau=tau,
        r=r,
        sigma=sigma,
        n_paths=n_paths_bs,
        seed=seed_bs
    )

    bs_mc = sample_moments(terminal_bs)

    # Merton-Garman Monte Carlo.
    terminal_mg, integrated_variance, variance_brownian_integral = (
        simulate_merton_garman_terminal_price(
            S0=S0,
            tau=tau,
            r=r,
            v0=v0,
            mu_tilde=mg_params["mu_tilde"],
            xi=mg_params["xi"],
            rho=mg_params["rho"],
            n_paths=n_paths_mg,
            n_steps=n_steps_mg,
            seed=seed_mg
        )
    )

    mg_mc = sample_moments(terminal_mg)

    # Conditional moment estimator for Merton-Garman.
    mg_raw_conditional = conditional_raw_moments_merton_garman(
        S0=S0,
        tau=tau,
        r=r,
        rho=mg_params["rho"],
        integrated_variance=integrated_variance,
        variance_brownian_integral=variance_brownian_integral,
        orders=(1, 2, 3, 4)
    )

    mg_conditional = central_moments_from_raw(mg_raw_conditional)

    result = {
        "symbol": symbol,
        "estimation_status": estimation_status,
        "date": contract["date"],
        "expiration": contract["expiration"],
        "strike": contract["strike"],
        "S0": S0,
        "tau": tau,
        "sigma_iv": sigma,
        "v0": v0,
        "mu_tilde": mg_params["mu_tilde"],
        "xi": mg_params["xi"],
        "rho": mg_params["rho"],

        "BS_closed_mean": bs_closed["mean"],
        "BS_closed_variance": bs_closed["variance"],
        "BS_closed_skewness": bs_closed["skewness"],
        "BS_closed_kurtosis": bs_closed["kurtosis"],

        "BS_mc_mean": bs_mc["mean"],
        "BS_mc_variance": bs_mc["variance"],
        "BS_mc_skewness": bs_mc["skewness"],
        "BS_mc_kurtosis": bs_mc["kurtosis"],
        "BS_mc_se_mean": bs_mc["se_mean"],

        "MG_mc_mean": mg_mc["mean"],
        "MG_mc_variance": mg_mc["variance"],
        "MG_mc_skewness": mg_mc["skewness"],
        "MG_mc_kurtosis": mg_mc["kurtosis"],

        "MG_conditional_mean": mg_conditional["mean"],
        "MG_conditional_variance": mg_conditional["variance"],
        "MG_conditional_skewness": mg_conditional["skewness"],
        "MG_conditional_kurtosis": mg_conditional["kurtosis"],
    }

    simulation_output = {
        "sv_series": sv_series,
        "terminal_bs": terminal_bs,
        "terminal_mg": terminal_mg,
        "contract": contract,
        "mg_params": mg_params
    }

    return result, simulation_output

def plot_reconstructed_series(series, symbol):
    """
    Plot reconstructed spot price and implied volatility series.
    """

    figure_path_price = FIGURES_DIR / f"{symbol.lower()}_reconstructed_spot.png"
    figure_path_vol = FIGURES_DIR / f"{symbol.lower()}_implied_volatility.png"

    plt.figure(figsize=(10, 4))
    plt.plot(series["date"], series["S"])
    plt.title(f"{symbol} - Reconstructed underlying price")
    plt.xlabel("Date")
    plt.ylabel("Reconstructed S")
    plt.tight_layout()
    plt.savefig(figure_path_price, dpi=300, bbox_inches="tight")
    plt.show()

    plt.figure(figsize=(10, 4))
    plt.plot(series["date"], series["sigma"])
    plt.title(f"{symbol} - Implied volatility")
    plt.xlabel("Date")
    plt.ylabel("Implied volatility")
    plt.tight_layout()
    plt.savefig(figure_path_vol, dpi=300, bbox_inches="tight")
    plt.show()

    print(f"Saved figures: {figure_path_price}, {figure_path_vol}")


def plot_terminal_price_distributions(
    symbol,
    terminal_bs,
    terminal_mg,
    S0,
    tau
):
    """
    Plot terminal price distributions under BS and MG.
    """

    all_values = np.concatenate([terminal_bs, terminal_mg])
    lower = np.percentile(all_values, 0.5)
    upper = np.percentile(all_values, 99.5)

    bins = np.linspace(lower, upper, 80)

    figure_path = FIGURES_DIR / f"{symbol.lower()}_bs_vs_mg_distribution.png"

    plt.figure(figsize=(9, 5))
    plt.hist(
        terminal_bs,
        bins=bins,
        density=True,
        alpha=0.5,
        label="Black-Scholes MC"
    )
    plt.hist(
        terminal_mg,
        bins=bins,
        density=True,
        alpha=0.5,
        label="Merton-Garman MC"
    )

    plt.axvline(S0, linestyle="--", color="black", label="Initial reconstructed S")

    plt.title(f"{symbol} - Terminal price distribution, tau = {tau:.3f} years")
    plt.xlabel("Terminal price")
    plt.ylabel("Density")
    plt.legend()
    plt.tight_layout()
    plt.savefig(figure_path, dpi=300, bbox_inches="tight")
    plt.show()

    print(f"Saved figure: {figure_path}")


def plot_moment_comparison(results_df):
    """
    Plot selected moment comparison across symbols.
    """

    figure_path = FIGURES_DIR / "moment_comparison_bs_mg.png"

    plot_columns = [
        "BS_mc_variance",
        "MG_mc_variance",
        "MG_conditional_variance"
    ]

    plot_data = results_df.set_index("symbol")[plot_columns]

    plt.figure(figsize=(10, 5))
    plot_data.plot(kind="bar", figsize=(10, 5))

    plt.title("Variance comparison across models")
    plt.xlabel("Symbol")
    plt.ylabel("Variance")
    plt.xticks(rotation=0)
    plt.tight_layout()
    plt.savefig(figure_path, dpi=300, bbox_inches="tight")
    plt.show()

    print(f"Saved figure: {figure_path}")

def run_full_analysis(
    symbols=SYMBOLS,
    r=RISK_FREE_RATE,
    n_paths_bs=N_PATHS_BS,
    n_paths_mg=N_PATHS_MG,
    n_steps_mg=N_STEPS_MG
):
    """
    Run the complete project analysis for all symbols.
    """

    options, volatilities = load_symbol_data(symbols)

    results = []
    simulations = {}

    for symbol in symbols:
        print(f"\n=== Processing {symbol} ===")

        try:
            result, simulation_output = analyze_symbol(
                symbol=symbol,
                option_data=options[symbol],
                volatility_data=volatilities[symbol],
                r=r,
                n_paths_bs=n_paths_bs,
                n_paths_mg=n_paths_mg,
                n_steps_mg=n_steps_mg,
                seed_bs=SEED_BS,
                seed_mg=SEED_MG
            )

            results.append(result)
            simulations[symbol] = simulation_output

            plot_reconstructed_series(
                series=simulation_output["sv_series"],
                symbol=symbol
            )

            plot_terminal_price_distributions(
                symbol=symbol,
                terminal_bs=simulation_output["terminal_bs"],
                terminal_mg=simulation_output["terminal_mg"],
                S0=result["S0"],
                tau=result["tau"]
            )

        except Exception as error:
            print(f"Analysis failed for {symbol}: {error}")

    results_df = pd.DataFrame(results)

    if results_df.empty:
        raise ValueError("No successful symbol analysis was completed.")

    results_csv = TABLES_DIR / "results_moments_bs_mg.csv"
    results_excel = TABLES_DIR / "results_moments_bs_mg.xlsx"

    results_df.to_csv(results_csv, index=False)
    results_df.to_excel(results_excel, index=False)

    print(f"\nSaved results to: {results_csv}")
    print(f"Saved Excel file to: {results_excel}")

    plot_moment_comparison(results_df)

    return results_df, simulations

results_df, simulations = run_full_analysis(
    symbols=SYMBOLS,
    r=RISK_FREE_RATE,
    n_paths_bs=N_PATHS_BS,
    n_paths_mg=N_PATHS_MG,
    n_steps_mg=N_STEPS_MG
)

